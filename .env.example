# ============================================================
# PASE DIGITAL QR — Variables de entorno
# Copia este archivo como .env y completa los valores
# NUNCA subas .env a Git
# ============================================================

# ------------------------------------------------------------
# BASE DE DATOS
# ------------------------------------------------------------

# OPCIÓN A — Desarrollo local con SQLite (sin cambios en schema.prisma)
# Si quieres usar SQLite local, cambia provider="sqlite" en prisma/schema.prisma
# DATABASE_URL="file:./db/custom.db"
# DIRECT_URL="file:./db/custom.db"

# OPCIÓN B — Supabase PostgreSQL (producción y desarrollo con Postgres)
# Obtén estas URLs desde: Supabase → Settings → Database → Connection string

# Transaction pooler (para la app — usa pgBouncer, ideal para serverless)
# Formato: postgresql://postgres.XXXXX:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=""

# Direct connection (solo para migraciones — sin pgBouncer)
# Formato: postgresql://postgres.XXXXX:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
DIRECT_URL=""

# ------------------------------------------------------------
# SESIONES
# ------------------------------------------------------------
# Genera una cadena aleatoria larga para producción:
# Ejemplo con Node: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""

# CORS - comma-separated list of allowed origins (leave empty to allow all)
ALLOWED_ORIGINS=""
