# ============================================================
# MEMBEGO PLATFORM — Variables de entorno
# Copia este archivo como .env y completa los valores
# NUNCA subas .env a Git
# ============================================================

# ------------------------------------------------------------
# BASE DE DATOS (Supabase PostgreSQL)
# Obtén estas URLs desde: Supabase → Settings → Database → Connection string
# ------------------------------------------------------------

# Transaction pooler — usa pgBouncer, ideal para serverless (Prisma en prod)
# Formato: postgresql://postgres.XXXXX:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=""

# Direct connection — sin pgBouncer, solo para migraciones (prisma migrate)
# Formato: postgresql://postgres.XXXXX:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
DIRECT_URL=""

# ------------------------------------------------------------
# SUPABASE AUTH
# Obtén estas claves desde: Supabase → Settings → API
# ------------------------------------------------------------

# URL del proyecto Supabase (pública, va al frontend)
NEXT_PUBLIC_SUPABASE_URL=""

# Clave anon/pública (safe para el navegador)
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Clave service_role (PRIVADA — solo backend/server actions)
SUPABASE_SERVICE_ROLE_KEY=""

# ------------------------------------------------------------
# DOMINIO Y MARCA (MembeGo)
# ------------------------------------------------------------

# URL base oficial de producción. Se usa para metadata/OG/canonical, sitemap,
# enlaces de referido y correos. Sin barra final.
NEXT_PUBLIC_APP_URL="https://membego.com"

# ------------------------------------------------------------
# CORREO (Resend)
# ------------------------------------------------------------

# Remitente de los correos del sistema. El dominio membego.com debe estar
# verificado en Resend (DNS) para que el envío funcione.
EMAIL_FROM="MembeGo <no-reply@membego.com>"

# API key de Resend (privada). Sin ella, el envío de correo queda deshabilitado.
RESEND_API_KEY=""
