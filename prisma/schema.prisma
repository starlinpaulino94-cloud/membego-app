generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String   @id @default(cuid())
  supabaseId  String   @unique
  email       String   @unique
  name        String
  role        AppRole  @default(CLIENTE)
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  memberships Membership[]
  visits      Visit[]  @relation("EmpleadoVisits")

  @@map("users")
}

enum AppRole {
  SUPERADMIN
  ADMIN_EMPRESA
  EMPLEADO
  CLIENTE
}

model Company {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  type        String
  description String?
  logoUrl     String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  users       User[]
  plans       Plan[]
  clientes    Cliente[]

  @@map("companies")
}

model Plan {
  id               String       @id @default(cuid())
  companyId        String
  company          Company      @relation(fields: [companyId], references: [id])
  nombre           String
  precio           Decimal      @db.Decimal(10, 2)
  lavadosIncluidos Int          @default(0)
  esIlimitado      Boolean      @default(false)
  descripcion      String?
  beneficios       String[]
  activo           Boolean      @default(true)
  createdAt        DateTime     @default(now())
  memberships      Membership[]

  @@map("plans")
}

model Cliente {
  id              String       @id @default(cuid())
  companyId       String
  company         Company      @relation(fields: [companyId], references: [id])
  supabaseId      String
  nombre          String
  telefono        String?
  email           String
  fechaNacimiento DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  vehiculos       Vehiculo[]
  memberships     Membership[]
  qrTokens        QrToken[]
  visits          Visit[]

  @@unique([supabaseId, companyId])
  @@map("clientes")
}

model Vehiculo {
  id        String   @id @default(cuid())
  clienteId String
  cliente   Cliente  @relation(fields: [clienteId], references: [id])
  marca     String
  modelo    String
  anio      Int
  color     String
  placa     String?
  createdAt DateTime @default(now())
  visits    Visit[]

  @@map("vehiculos")
}

model Membership {
  id               String           @id @default(cuid())
  clienteId        String
  cliente          Cliente          @relation(fields: [clienteId], references: [id])
  planId           String
  plan             Plan             @relation(fields: [planId], references: [id])
  userId           String?
  user             User?            @relation(fields: [userId], references: [id])
  estado           MembershipEstado @default(PENDIENTE)
  fechaInicio      DateTime?
  fechaVencimiento DateTime?
  lavadosRestantes Int              @default(0)
  montoPagado      Decimal?         @db.Decimal(10, 2)
  pagoConfirmado   Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  visits           Visit[]

  @@map("memberships")
}

enum MembershipEstado {
  PENDIENTE
  ACTIVA
  VENCIDA
  CANCELADA
}

model QrToken {
  id        String   @id @default(cuid())
  clienteId String
  cliente   Cliente  @relation(fields: [clienteId], references: [id])
  token     String   @unique @default(cuid())
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("qr_tokens")
}

model Visit {
  id           String     @id @default(cuid())
  clienteId    String
  cliente      Cliente    @relation(fields: [clienteId], references: [id])
  vehiculoId   String?
  vehiculo     Vehiculo?  @relation(fields: [vehiculoId], references: [id])
  membershipId String
  membership   Membership @relation(fields: [membershipId], references: [id])
  empleadoId   String?
  empleado     User?      @relation("EmpleadoVisits", fields: [empleadoId], references: [id])
  servicio     String
  descontado   Boolean    @default(false)
  fechaVisita  DateTime   @default(now())
  notas        String?
  createdAt    DateTime   @default(now())

  @@map("visits")
}
